{
  "name": "@kyntic/discovery-agent",
  "version": "0.1.0",
  "description": "Local-only MCP server and CLI for auditing codebases and generating KynticAI Scout handovers.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "kyntic-discovery-mcp": "./dist/kyntic-discovery-mcp.js",
    "kyntic-discovery-agent": "./dist/index.js",
    "discovery-agent": "./dist/index.js"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "examples",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prebuild": "npm --prefix ../../packages/typescript/scout-discovery-mcp install --no-save --no-package-lock && npm --prefix ../../packages/typescript/scout-discovery-mcp run build",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "start": "node dist/index.js",
    "smoke:tier1": "node dist/index.js --path ../.. --tier 1"
  },
  "dependencies": {
    "@kynticai/scout-discovery-mcp": "file:../../packages/typescript/scout-discovery-mcp",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
