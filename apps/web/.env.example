# Local dev uses the ASP.NET Core backend on port 5198.
VITE_API_BASE_URL=http://localhost:5198
VITE_GRAPHQL_ENDPOINT=http://localhost:5198/graphql
VITE_PILOT_LEAD_ENDPOINT=
VITE_PILOT_CONTACT_EMAIL=hello@universalcontextlayer.com
VITE_TURNSTILE_SITE_KEY=
VITE_SITE_OPERATOR_NAME=Paul Maddison, for the Universal Context Layer project
VITE_SITE_OPERATOR_LOCATION=United Kingdom
# Local demo fallback is for laptop demos only. Customer and production builds
# must keep this false so API failures are visible and never replaced by mock data.
VITE_DEMO_FALLBACK=false

# Hosted static-site builds should use the public API origin, for example:
# VITE_API_BASE_URL=https://<api-domain>
# VITE_GRAPHQL_ENDPOINT=https://<api-domain>/graphql
# VITE_PILOT_LEAD_ENDPOINT=https://<cloud-api-domain>/api/v1/crm/leads
# VITE_TURNSTILE_SITE_KEY=<cloudflare-turnstile-site-key>
# VITE_DEMO_FALLBACK=false
#
# Same-origin container builds can leave VITE_API_BASE_URL empty and use:
# VITE_GRAPHQL_ENDPOINT=/graphql
