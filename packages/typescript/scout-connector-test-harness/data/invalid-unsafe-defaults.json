{
  "manifest": {
    "connectorId": "unsafeDefaultConnector",
    "displayName": "Unsafe Default Connector",
    "version": "1.0.0",
    "description": "Manifest with unsafe default values in configuration schema.",
    "supportedSourceTypes": ["Crm"],
    "requiredConfigFields": [
      { "name": "endpoint", "type": "string", "description": "API endpoint." }
    ],
    "safeMetadataFields": ["displayName"],
    "sampleEntityMappings": [
      {
        "sourceField": "deal_probability",
        "semanticAttribute": "conversionProbability",
        "description": "Maps deal probability."
      }
