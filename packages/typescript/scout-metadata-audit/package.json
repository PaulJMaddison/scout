{
  "name": "@kynticai/scout-metadata-audit",
  "version": "2.8.0",
  "description": "Local-only metadata audit runner for KynticAI Scout connector manifests and sample data.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PaulJMaddison/scout.git",
    "directory": "packages/typescript/scout-metadata-audit"
  },
  "homepage": "https://github.com/PaulJMaddison/scout",
  "bugs": {
    "url": "https://github.com/PaulJMaddison/scout/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "scout-metadata-audit": "./dist/cli.js"
  },
  "sideEffects": false,
  "exports": {
