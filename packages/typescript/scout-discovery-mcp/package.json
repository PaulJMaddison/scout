{
  "name": "@kynticai/scout-discovery-mcp",
  "version": "2.8.0",
  "description": "MCP server for KynticAI Scout discovery — exposes public metadata inspection tools for AI agents.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PaulJMaddison/scout.git",
    "directory": "packages/typescript/scout-discovery-mcp"
  },
  "homepage": "https://github.com/PaulJMaddison/scout",
  "bugs": {
    "url": "https://github.com/PaulJMaddison/scout/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "scout-discovery-mcp": "./dist/index.js"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./tools": {
      "types": "./dist/tools.d.ts",
      "import": "./dist/tools.js"
    },
    "./sample-data": {
      "types": "./dist/sample-data.d.ts",
      "import": "./dist/sample-data.js"
    }
  },
  "files": [
    "dist",
    "data",
    "README.md"
  ],
  "scripts": {
    "prebuild": "npm --prefix ../scout-connector-validator install --no-save --no-package-lock && npm --prefix ../scout-connector-validator run build && npm --prefix ../scout-metadata-audit install --no-save --no-package-lock && npm --prefix ../scout-metadata-audit run build",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@kynticai/scout-connector-validator": "file:../scout-connector-validator",
    "@kynticai/scout-metadata-audit": "file:../scout-metadata-audit",
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
