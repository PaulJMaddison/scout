{
  "Platform": {
    "Mode": "SaaS",
    "EnableGraphQl": true,
    "EnableRest": true,
    "EnableOpenApi": true
  },
  "FeatureFlags": {
    "DemoExperience": false,
    "OpenCoreApis": true,
    "SaaSControlPlane": true,
    "HostedBillingUsage": true,
    "Webhooks": true,
    "EnterpriseConnectorExtensions": false
  },
  "Bootstrap": {
    "ApplyMigrationsOnStartup": false,
    "SeedDemoData": false
  },
  "ControlPlane": {
    "Enabled": false,
    "BaseUrl": "",
    "CustomerAccountId": "",
    "UpdateChannel": "stable",
    "UsageReportingEnabled": false,
    "OfflineGracePeriodDays": 30
  },
  "Licence": {
    "Mode": "Community",
    "FilePath": "/var/lib/ucl/licence.json",
    "RequireValidLicence": false,
    "OfflineGracePeriodDays": 30
  },
  "Database": {
    "Provider": "Postgres"
  },
  "Auth": {
    "Issuer": "ContextLayer",
    "Audience": "ContextLayer.Api",
    "SigningKey": "",
    "AccessTokenMinutes": 30,
    "RequireSecureSigningKey": true,
    "MinimumSigningKeyLength": 48,
    "MachineClients": []
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Telemetry": {
    "ServiceName": "ContextLayer.Api",
    "ServiceNamespace": "UniversalContextLayer",
    "DeploymentEnvironment": "production",
    "OtlpEndpoint": ""
  },
  "RateLimits": {
    "AuthPermitLimit": 5,
    "AuthWindowSeconds": 60,
    "GraphQlTokenLimit": 120,
    "GraphQlTokensPerPeriod": 120,
    "GraphQlReplenishmentSeconds": 60
  },
  "Logging": {
    "Console": {
      "FormatterName": "json"
    },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}
