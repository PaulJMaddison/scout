{
  "Database": {
    "Provider": "Sqlite"
  },
  "ConnectionStrings": {
    "ContextLayer": "Data Source=.demo-data/context_layer_demo.db",
    "CustomerOps": "Data Source=.demo-data/customer_ops_demo.db"
  },
  "Auth": {
    "Issuer": "ContextLayer",
    "Audience": "ContextLayer.Console",
    "SigningKey": "context-layer-dev-signing-key-change-me",
    "AccessTokenMinutes": 120
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  },
  "Telemetry": {
    "OtlpEndpoint": ""
  },
  "Llm": {
    "DefaultProvider": "mock",
    "DefaultModel": "gpt-5.5",
    "MaxAttempts": 2,
    "LowConfidenceThreshold": 0.75,
    "MinimumStrongFacts": 3
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
