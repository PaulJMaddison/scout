{
  "Platform": {
    "Mode": "LocalDemo",
    "EnableGraphQl": true,
    "EnableRest": true,
    "EnableOpenApi": true
  },
  "FeatureFlags": {
    "DemoExperience": true,
    "OpenCoreApis": true,
    "SaaSControlPlane": false,
    "HostedBillingUsage": false,
    "Webhooks": false,
    "EnterpriseConnectorExtensions": false,
    "AnonymousOnboarding": true,
    "AllowProductionOnboarding": false
  },
  "SaaS": {
    "PublicBaseUrl": "http://127.0.0.1:5198",
    "ApiIssuer": "KynticAI.Scout.SaaS",
    "RequireWorkspaceScope": false,
    "PersistApiClients": true
  },
  "Bootstrap": {
    "ApplyMigrationsOnStartup": true,
    "SeedDemoData": false
  },
  "DataProtection": {
    "ApplicationName": "KynticAIScout",
    "KeyRingPath": ".demo-data/data-protection-keys",
    "RequirePersistentKeys": false
  },
  "Database": {
    "Provider": "Sqlite"
  },
  "ConnectionStrings": {
    "Scout": "Data Source=.demo-data/scout_context_demo.db",
    "CustomerOps": "Data Source=.demo-data/customer_ops_demo.db"
  },
  "Auth": {
    "Issuer": "Scout",
    "Audience": "KynticAI.Scout.Console",
    "SigningKey": "scout-development-only-change-before-production",
    "AccessTokenMinutes": 120,
    "RequireSecureSigningKey": false,
    "MinimumSigningKeyLength": 32,
    "MachineClients": []
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  },
  "Telemetry": {
    "ServiceName": "KynticAI.Scout.Api",
    "ServiceNamespace": "KynticAIScout",
    "DeploymentEnvironment": "development",
    "OtlpEndpoint": ""
  },
  "RateLimits": {
    "AuthPermitLimit": 5,
    "AuthWindowSeconds": 60,
    "GraphQlTokenLimit": 600,
    "GraphQlTokensPerPeriod": 600,
    "GraphQlReplenishmentSeconds": 60
  },
  "Llm": {
    "DefaultProvider": "mock",
    "DefaultModel": "gpt-5.5",
    "MaxAttempts": 2,
    "LowConfidenceThreshold": 0.75,
    "MinimumStrongFacts": 3
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
