{
  "Platform": {
    "Mode": "SaaS",
    "EnableGraphQl": true,
    "EnableRest": true,
    "EnableOpenApi": false
  },
  "FeatureFlags": {
    "DemoExperience": false,
    "OpenCoreApis": true,
    "SaaSControlPlane": true,
    "HostedBillingUsage": true,
    "Webhooks": true,
    "EnterpriseConnectorExtensions": false,
    "AnonymousOnboarding": false,
    "AllowProductionOnboarding": false
  },
  "Bootstrap": {
    "ApplyMigrationsOnStartup": false,
    "SeedDemoData": false
  },
  "DataProtection": {
    "ApplicationName": "KynticAIScout",
    "KeyRingPath": "/var/lib/scout/data-protection-keys",
    "RequirePersistentKeys": true
  },
  "ControlPlane": {
    "Enabled": false,
    "BaseUrl": "",
    "CustomerAccountId": "",
    "UpdateChannel": "stable",
    "UsageReportingEnabled": false,
    "OfflineGracePeriodDays": 30
  },
  "Licence": {
    "Mode": "Community",
    "FilePath": "/var/lib/scout/licence.json",
    "RequireValidLicence": false,
    "OfflineGracePeriodDays": 30
  },
  "StorageAdapter": {
    "Provider": "scout-postgres",
    "VectorProvider": "disabled",
    "EnableEnterpriseRuntime": false,
    "EnableVectorWrites": false,
    "EnableDualWrite": false,
    "AllowCloudDataMovement": false,
    "EnterpriseRuntimeBaseUrl": "",
    "ExpectedEmbeddingDimensions": 384,
    "ExportCheckpointPath": "/var/lib/scout/storage-adapter-checkpoints"
  },
  "Database": {
    "Provider": "Postgres"
  },
  "Auth": {
    "Issuer": "Scout",
    "Audience": "KynticAI.Scout.Api",
    "SigningKey": "",
    "AccessTokenMinutes": 30,
    "RequireSecureSigningKey": true,
    "MinimumSigningKeyLength": 48,
    "MachineClients": []
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Telemetry": {
    "ServiceName": "KynticAI.Scout.Api",
    "ServiceNamespace": "KynticAIScout",
    "DeploymentEnvironment": "production",
    "OtlpEndpoint": ""
  },
  "GraphQl": {
    "MaxExecutionDepth": 12,
    "ExecutionTimeoutSeconds": 10,
    "DisableIntrospectionInProduction": true,
    "EnableGetRequestsInProduction": false,
    "EnableSchemaRequestsInProduction": false,
    "EnableMultipartRequests": false,
    "MaxBatchSize": 3,
    "MaxConcurrentExecutions": 24
  },
  "SecurityHeaders": {
    "Enabled": true,
    "EnableHsts": true,
    "ContentSecurityPolicy": "default-src 'none'; frame-ancestors 'none'; base-uri 'none'; form-action 'none'",
    "ReferrerPolicy": "strict-origin-when-cross-origin",
    "PermissionsPolicy": "camera=(), microphone=(), geolocation=(), payment=()",
    "FrameOptions": "DENY"
  },
  "RateLimits": {
    "AuthPermitLimit": 5,
    "AuthWindowSeconds": 60,
    "GraphQlTokenLimit": 120,
    "GraphQlTokensPerPeriod": 120,
    "GraphQlReplenishmentSeconds": 60
  },
  "Logging": {
    "Console": {
      "FormatterName": "json"
    },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}
