<Project>
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <AnalysisLevel>latest</AnalysisLevel>
    <LangVersion>preview</LangVersion>
    <InvariantGlobalization>true</InvariantGlobalization>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>
    <Version>1.1.0</Version>
    <AssemblyVersion>1.1.0.0</AssemblyVersion>
    <FileVersion>1.1.0.0</FileVersion>
    <InformationalVersion>1.1.0</InformationalVersion>
    <Product>Context Layer</Product>
    <Authors>Paul Maddison and contributors</Authors>
    <Company>Universal Context Layer</Company>
    <RepositoryUrl>https://github.com/PaulJMaddison/universalcontextlayer</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/PaulJMaddison/universalcontextlayer</PackageProjectUrl>
    <PackageTags>ai;graphql;dotnet;react;semantic-layer;context-engineering;sales-intelligence</PackageTags>
    <PackageReleaseNotes>1.1.0 release with outcome-led product messaging across every page, clearer fresh-laptop SQLite setup documentation, refreshed README screenshots, removal of GitHub Actions workflows, and a stronger executive and technical demo narrative.</PackageReleaseNotes>
  </PropertyGroup>
</Project>
