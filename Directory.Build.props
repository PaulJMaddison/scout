<Project>
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <AnalysisLevel>latest</AnalysisLevel>
    <LangVersion>preview</LangVersion>
    <InvariantGlobalization>true</InvariantGlobalization>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>
    <Version>2.5.1</Version>
    <AssemblyVersion>2.5.1.0</AssemblyVersion>
    <FileVersion>2.5.1.0</FileVersion>
    <InformationalVersion>2.5.1</InformationalVersion>
    <Product>Context Layer</Product>
    <Authors>Paul Maddison and contributors</Authors>
    <Company>Universal Context Layer</Company>
    <RepositoryUrl>https://github.com/PaulJMaddison/universalcontextlayer</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/PaulJMaddison/universalcontextlayer</PackageProjectUrl>
    <PackageTags>context-infrastructure;graphql;rest;dotnet;react;semantic-layer;context-engineering;open-core</PackageTags>
    <PackageReleaseNotes>2.5.1 GitHub Pages activation patch with live static-demo URL, repository homepage metadata, and Pages-friendly .nojekyll build output.</PackageReleaseNotes>
  </PropertyGroup>
</Project>
