# ──────────────────────────────────────────────────────────────────────────────
# Universal Context Layer — Docker Compose Environment
# Copy this file to deploy/.env and customise as needed.
# ──────────────────────────────────────────────────────────────────────────────

# ── Platform ─────────────────────────────────────────────────────────────────
# BackendOnly = API-only (GraphQL + REST), no React UI
# LocalDemo   = API + seeded demo data + React demo experience
PLATFORM_MODE=BackendOnly

# ── Ports ────────────────────────────────────────────────────────────────────
UCL_PORT=8080

# ── Demo Data ────────────────────────────────────────────────────────────────
# Set to true to seed fictional B2B SaaS demo data on first startup.
SEED_DEMO_DATA=true

# ── Authentication ───────────────────────────────────────────────────────────
# IMPORTANT: Replace this with a secure random string (48+ bytes) for production.
AUTH_SIGNING_KEY=context-layer-development-only-change-before-production
AUTH_ACCESS_TOKEN_MINUTES=120

# ── OpenAPI / Swagger ────────────────────────────────────────────────────────
# Enable Swagger UI at /swagger (disable in production).
ENABLE_OPENAPI=true

# ── PostgreSQL (only used with --profile postgres) ───────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
CUSTOMER_OPS_DB=customer_ops_db
CONTEXT_LAYER_DB=context_layer_db
