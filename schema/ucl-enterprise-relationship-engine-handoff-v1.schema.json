{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.kynticai.com/ucl/evidence-pack/v1/ucl-enterprise-relationship-engine-handoff-v1.schema.json",
  "title": "UclEnterpriseRelationshipEngineHandoffV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactKind",
    "artifactVersion",
    "handoffId",
    "packageKind",
    "packageVersion",
    "packageId",
    "generatedAtUtc",
    "tenantSlug",
    "dataPlane",
    "producer",
    "fallbackEngine",
    "relationshipWeighting",
    "requiresLiveEnterpriseService",
    "enterpriseOnlyInternalsIncluded",
    "subject",
    "objective",
    "purpose",
    "actorRole",
    "evidenceSummary",
    "candidateRelationships",
    "provenance",
    "requiredEnterpriseOutputs"
  ],
  "properties": {
    "artifactKind": { "const": "ucl.enterprise-relationship-engine-handoff" },
    "artifactVersion": { "const": "ucl.enterprise-relationship-engine-handoff.v1" },
    "handoffId": { "type": "string", "minLength": 1 },
    "packageKind": { "const": "ucl.evidence-pack" },
    "packageVersion": { "const": "ucl.evidence-pack.v1" },
    "packageId": { "type": "string", "minLength": 1 },
    "generatedAtUtc": { "type": "string", "format": "date-time" },
    "tenantSlug": { "type": "string", "minLength": 1 },
    "dataPlane": { "const": "customer-owned-data-plane" },
    "producer": { "type": "string", "minLength": 1 },
    "fallbackEngine": { "const": "BasicRelationshipEngine" },
    "relationshipWeighting": { "$ref": "#/$defs/relationshipWeighting" },
    "requiresLiveEnterpriseService": { "const": false },
    "enterpriseOnlyInternalsIncluded": { "const": false },
    "subject": { "$ref": "#/$defs/subject" },
    "objective": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 1 },
    "actorRole": { "type": "string", "minLength": 1 },
    "evidenceSummary": { "$ref": "#/$defs/evidenceSummary" },
    "candidateRelationships": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/candidateRelationship" }
    },
    "provenance": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/provenanceCitation" }
    },
    "requiredEnterpriseOutputs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "contains": { "const": "canonicalRelationshipWeights" }
    }
  },
  "$defs": {
    "relationshipWeighting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "scoutWeightsAreCanonical", "canonicalOwner", "canonicalEngine"],
      "properties": {
        "scope": { "const": "basic-public-fallback-demo" },
        "scoutWeightsAreCanonical": { "const": false },
        "canonicalOwner": { "const": "Enterprise" },
        "canonicalEngine": { "type": "string", "minLength": 1 }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subjectType", "subjectIdentifier", "externalAccountId", "primaryContactId"],
      "properties": {
        "subjectType": { "type": "string", "minLength": 1 },
        "subjectIdentifier": { "type": "string", "minLength": 1 },
        "externalAccountId": { "type": "string", "minLength": 1 },
        "primaryContactId": {
          "anyOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        }
      }
    },
    "evidenceSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recordCounts", "exactRecordCount", "candidateRelationshipCount", "provenanceCitationCount"],
      "properties": {
        "recordCounts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "exactRecordCount": { "type": "integer", "minimum": 0 },
        "candidateRelationshipCount": { "type": "integer", "minimum": 0 },
        "provenanceCitationCount": { "type": "integer", "minimum": 0 }
      }
    },
    "candidateRelationship": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relationshipId",
        "relationshipType",
        "linkKind",
        "sourceType",
        "sourceId",
        "targetType",
        "targetId",
        "confidence",
        "scoutFallbackWeight",
        "fallbackWeightScope",
        "rationale",
        "citationIds"
      ],
      "properties": {
        "relationshipId": { "type": "string", "minLength": 1 },
        "relationshipType": { "type": "string", "minLength": 1 },
        "linkKind": { "type": "string", "minLength": 1 },
        "sourceType": { "type": "string", "minLength": 1 },
        "sourceId": { "type": "string", "minLength": 1 },
        "targetType": { "type": "string", "minLength": 1 },
        "targetId": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "scoutFallbackWeight": { "type": "number" },
        "fallbackWeightScope": { "const": "basic-public-fallback-demo" },
        "rationale": { "type": "string", "minLength": 1 },
        "citationIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "provenanceCitation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["citationId", "sourceEntityType", "sourceEntityId", "evidenceType", "summary", "isMasked"],
      "properties": {
        "citationId": { "type": "string", "minLength": 1 },
        "sourceEntityType": { "type": "string", "minLength": 1 },
        "sourceEntityId": { "type": "string", "minLength": 1 },
        "evidenceType": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "isMasked": { "type": "boolean" }
      }
    }
  }
}
