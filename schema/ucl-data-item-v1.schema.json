{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.kynticai.com/ucl/data-item/v1/ucl-data-item-v1.schema.json",
  "title": "DataItem",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "itemKind",
    "itemVersion",
    "dataItemId",
    "dataItemType",
    "sourceMode",
    "sourceSystem",
    "sourceRecordId",
    "observedAtUtc",
    "ingestedAtUtc",
    "dataPlane",
    "identities",
    "exactPayload"
  ],
  "properties": {
    "itemKind": { "const": "ucl.data-item" },
    "itemVersion": { "const": "ucl.data-item.v1" },
    "dataItemId": { "type": "string", "minLength": 1 },
    "dataItemType": {
      "type": "string",
      "minLength": 1,
      "examples": [
        "customer",
        "email_address",
        "browser_cookie",
        "web_event",
        "email_enquiry",
        "product_browse_search",
        "account_registration",
        "sales_opportunity",
        "support_event",
        "purchase_subscription_billing_aggregate"
      ]
    },
    "sourceMode": {
      "type": "string",
      "minLength": 1,
      "examples": ["connector", "assisted_import"]
    },
    "sourceSystem": { "type": "string", "minLength": 1 },
    "sourceRecordId": { "type": "string", "minLength": 1 },
    "observedAtUtc": { "type": "string", "format": "date-time" },
    "ingestedAtUtc": { "type": "string", "format": "date-time" },
    "dataPlane": { "const": "customer-owned-data-plane" },
    "identities": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/dataItemIdentity" }
    },
    "exactPayload": {
      "type": "object",
      "description": "Exact local source payload retained in the customer-owned data plane.",
      "additionalProperties": true
    }
  },
  "$defs": {
    "dataItemIdentity": {
      "title": "DataItemIdentity",
      "type": "object",
      "additionalProperties": false,
      "required": ["identityType", "identityValue", "normalizedValue", "isPrimary", "linkScope"],
      "properties": {
        "identityType": { "type": "string", "minLength": 1 },
        "identityValue": { "type": "string", "minLength": 1 },
        "normalizedValue": { "type": "string", "minLength": 1 },
        "isPrimary": { "type": "boolean" },
        "linkScope": { "type": "string", "minLength": 1 }
      }
    }
  }
}
