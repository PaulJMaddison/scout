# Local demo defaults use two SQLite databases under .demo-data/ and do not require Docker.
# Hosted SaaS deployments should override the production values noted below in the host dashboard.
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://127.0.0.1:5198
Platform__Mode=LocalDemo
Platform__EnableGraphQl=true
Platform__EnableRest=true
Platform__EnableOpenApi=true
FeatureFlags__DemoExperience=true
FeatureFlags__OpenCoreApis=true
FeatureFlags__SaaSControlPlane=false
FeatureFlags__HostedBillingUsage=false
FeatureFlags__Webhooks=false
FeatureFlags__EnterpriseConnectorExtensions=false
FeatureFlags__AnonymousOnboarding=true
FeatureFlags__AllowProductionOnboarding=false
SaaS__PublicBaseUrl=http://127.0.0.1:5198
SaaS__ApiIssuer=ContextLayer.SaaS
SaaS__RequireWorkspaceScope=false
SaaS__PersistApiClients=true
ControlPlane__Enabled=false
ControlPlane__BaseUrl=
ControlPlane__CustomerAccountId=
ControlPlane__UpdateChannel=stable
ControlPlane__UsageReportingEnabled=false
ControlPlane__OfflineGracePeriodDays=30
Licence__Mode=Community
Licence__FilePath=.demo-data/ucl-demo.licence.json
Licence__RequireValidLicence=false
Licence__OfflineGracePeriodDays=30
Database__Provider=Sqlite
Bootstrap__ApplyMigrationsOnStartup=true
Bootstrap__SeedDemoData=false
DataProtection__ApplicationName=UniversalContextLayer
DataProtection__KeyRingPath=.demo-data/data-protection-keys
DataProtection__RequirePersistentKeys=false
Billing__Provider=none
# Payment-provider credentials belong in private cloud/control-plane configuration, not in the open-core product repo.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
CUSTOMER_OPS_DB=customer_ops_db
CONTEXT_LAYER_DB=context_layer_db
ConnectionStrings__CustomerOps=Host=localhost;Port=5432;Database=customer_ops_db;Username=postgres;Password=postgres
ConnectionStrings__ContextLayer=Host=localhost;Port=5432;Database=context_layer_db;Username=postgres;Password=postgres
Telemetry__ServiceName=ContextLayer.Api
Telemetry__ServiceNamespace=UniversalContextLayer
Telemetry__DeploymentEnvironment=local
Telemetry__OtlpEndpoint=http://localhost:4317
Auth__Issuer=ContextLayer
Auth__Audience=ContextLayer.Console
Auth__SigningKey=replace-with-at-least-32-random-bytes-for-hosted-mode
Auth__AccessTokenMinutes=30
Auth__RequireSecureSigningKey=true
Auth__MinimumSigningKeyLength=32
Cors__AllowedOrigins__0=http://localhost:5173
Cors__AllowedOrigins__1=http://127.0.0.1:5173
RateLimits__AuthPermitLimit=5
RateLimits__AuthWindowSeconds=60
RateLimits__GraphQlTokenLimit=60
RateLimits__GraphQlTokensPerPeriod=60
RateLimits__GraphQlReplenishmentSeconds=60
Llm__DefaultProvider=mock
Llm__DefaultModel=gpt-5.5
Llm__MaxAttempts=2
Llm__LowConfidenceThreshold=0.75
Llm__MinimumStrongFacts=3
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Static frontend build values. Leave VITE_API_BASE_URL empty only when the frontend
# and API are served from the same origin, such as the bundled nginx container.
VITE_API_BASE_URL=http://127.0.0.1:5198
VITE_GRAPHQL_ENDPOINT=http://127.0.0.1:5198/graphql
VITE_DEMO_FALLBACK=false

# Hosted production checklist:
# ASPNETCORE_ENVIRONMENT=Production
# Platform__Mode=SaaS
# Database__Provider=Postgres
# Bootstrap__ApplyMigrationsOnStartup=false
# Bootstrap__SeedDemoData=false
# DataProtection__KeyRingPath=/var/lib/ucl/data-protection-keys
# DataProtection__RequirePersistentKeys=true
# ConnectionStrings__ContextLayer=<managed PostgreSQL connection string for control-plane DB>
# ConnectionStrings__CustomerOps=<managed PostgreSQL connection string for source/demo operational DB>
# Auth__Issuer=ContextLayer
# Auth__Audience=ContextLayer.Api
# Auth__SigningKey=<48+ byte random secret, never committed>
# Cors__AllowedOrigins__0=https://<frontend-domain>
# SaaS__PublicBaseUrl=https://<api-domain>
# ControlPlane__Enabled=false
# Licence__Mode=Community
# Licence__FilePath=/var/lib/ucl/licence.json
# Licence__RequireValidLicence=false
# Telemetry__OtlpEndpoint=<optional OTLP collector endpoint>
