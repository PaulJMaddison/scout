ASPNETCORE_ENVIRONMENT=Development
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
CUSTOMER_OPS_DB=customer_ops_db
CONTEXT_LAYER_DB=context_layer_db
ConnectionStrings__CustomerOps=Host=localhost;Port=5432;Database=customer_ops_db;Username=postgres;Password=postgres
ConnectionStrings__ContextLayer=Host=localhost;Port=5432;Database=context_layer_db;Username=postgres;Password=postgres
Telemetry__OtlpEndpoint=http://localhost:4317
Auth__Issuer=ContextLayer
Auth__Audience=ContextLayer.Console
Auth__SigningKey=context-layer-dev-signing-key-change-me
Auth__AccessTokenMinutes=120
Cors__AllowedOrigins__0=http://localhost:5173
Cors__AllowedOrigins__1=http://127.0.0.1:5173
Llm__DefaultProvider=mock
Llm__DefaultModel=gpt-5.5
Llm__MaxAttempts=2
Llm__LowConfidenceThreshold=0.75
Llm__MinimumStrongFacts=3
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
